{
  "name": "gloomhaven",
  "private": true,
  "version": "6.0.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "node scripts/generate-changelog.cjs",
    "build": "vite build",
    "build:check": "node scripts/generate-changelog.cjs && vue-tsc -b && vite build",
